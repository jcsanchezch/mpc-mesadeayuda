APP_NAME='Mesa de Ayuda'
APP_ENV=production
APP_KEY=
APP_DEBUG=true
APP_URL=https://mesadeayuda.municaj.gob.pe

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

PG181_CONNECTION='pgsql'
PG181_HOST=''
PG181_PORT=''
PG181_USERNAME=''
PG181_PASSWORD=''
PG181_DATABASE=''

PG182_CONNECTION='pgsql'
PG182_HOST=''
PG182_PORT=''
PG182_USERNAME=''
PG182_PASSWORD=''
PG182_DATABASE=''

SESSION_DRIVER=database
SESSION_LIFETIME=600
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=mesadeayuda.municaj.gob.pe
# null
SESSION_SECURE_COOKIE=true
# false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

QUEUE_CONNECTION=sync

CACHE_STORE=array

VITE_APP_NAME="${APP_NAME}"

AUTH_URL='https://api-autenticacion.municaj.gob.pe/api/autenticacion'
AUTH_CODIGO=''
AUTH_CLAVE=''
